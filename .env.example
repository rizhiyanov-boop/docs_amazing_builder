# Server-side environment for local Vercel dev / production deployment.
# Never commit the real .env file to Git. Keep only this example in the repo.

# Required for server-side project storage and auth API.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Alternative Neon alias supported by api/_lib/db.ts.
# POSTGRES_URL=postgres://user:password@host:5432/dbname

# Required only for AI helpers (/api/ai and /api/openrouter alias).
OPENAI_API_KEY=sk-proj-REPLACE_ME

# Optional. Defaults to gpt-4.1-nano.
OPENAI_MODEL=gpt-4.1-nano
