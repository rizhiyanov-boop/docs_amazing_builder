    {
      "id": "method-auth",
      "name": "Auth Token Issue",
      "updatedAt": "2026-03-18T12:30:00.000Z",
      "sections": [
        {
          "id": "goal",
          "title": "Goal",
          "enabled": true,
          "kind": "text",
          "value": "Issue access token for customer channels and return token metadata.",
          "required": true
        },
        {
          "id": "functional",
          "title": "Functional Requirements",
          "enabled": true,
          "kind": "text",
          "value": "Validate credentials, create session, return token and TTL, log audit record."
        },
        {
          "id": "process-diagram",
          "title": "Process Diagram",
          "enabled": true,
          "kind": "diagram",
          "diagrams": [
            {
              "id": "diag-auth-sequence",
              "title": "Auth Sequence",
              "engine": "mermaid",
              "code": "sequenceDiagram\nparticipant Client\nparticipant API\nparticipant IAM\nClient->>API: POST /v1/auth/token\nAPI->>IAM: validate credentials\nIAM-->>API: OK + subject\nAPI-->>Client: accessToken + expiresIn",
              "description": "Main synchronous flow for token issuance."
            },
            {
              "id": "diag-auth-alt",
              "title": "Alternative View",
              "engine": "plantuml",
              "code": "@startuml\nactor Client\nparticipant API\nparticipant IAM\nClient -> API: POST /v1/auth/token\nAPI -> IAM: validate\nIAM --> API: subject\nAPI --> Client: token\n@enduml",
              "description": "PlantUML variant to exercise both engines."
            }
          ]
        },
